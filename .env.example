# Vercel BFF and Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
APP_ORIGIN=https://your-deployment.vercel.app

# S3 or Cloudflare R2 (S3-compatible) transient audio bucket
S3_BUCKET=pronunciation-transient
S3_REGION=auto
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret

# Separate FastAPI ASR service, ideally a GPU deployment
ASR_SERVICE_URL=https://asr.example.com
ASR_SERVICE_TOKEN=shared-service-token

# Required in production. Upstash Redis is used for per-user ASR rate limits.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Optional error monitoring for Vercel and the FastAPI service
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
METRICS_TOKEN=long-random-token-for-prometheus

# Existing optional text-only coaching
LLM_BASE_URL=https://your-inference-host/v1
LLM_API_KEY=server-side-secret
QWEN3_MODEL=Qwen/Qwen3-4B
GEMMA3_MODEL=google/gemma-3-4b-it
